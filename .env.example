# =============================================================================
# PROJECT MONTAGE — Environment Variables Example
# =============================================================================
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# -----------------------------------------------------------------------------
# LLM / AI APIs
# -----------------------------------------------------------------------------

# Google Gemini API key (used by ScriptwriterAgent via langchain-google-genai)
# Also accepted as GEMINI_API_KEY (both are checked in test_pipeline.py)
GOOGLE_API_KEY=your_google_api_key_here

# -----------------------------------------------------------------------------
# Hugging Face
# -----------------------------------------------------------------------------

# HuggingFace API token
# Used for: TTS (mcp_handler.py), image generation (mcp_handler.py),
#           video generation via LTX-Video (video_gen.py), SadTalker (lip_sync.py)
# Both HF_TOKEN and HF_API_TOKEN are checked — set either one (or both)
HF_TOKEN=your_huggingface_token_here
HF_API_TOKEN=your_huggingface_token_here

# HuggingFace TTS model (used in mcp_handler.py voice fallback)
HF_TTS_MODEL=facebook/mms-tts-eng

# HuggingFace image generation — comma-separated fallbacks (InferenceClient + HTTP).
# Default in code tries FLUX schnell then SDXL then SD 1.5; drop FLUX if you lack access.
HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell,stabilityai/stable-diffusion-xl-base-1.0,runwayml/stable-diffusion-v1-5

# Character portraits (mcp/tools/vision_tools/image_gen_tool.py):
# Pollinations first (rate limits/timeouts → multi-round retry + backoff).
# Pollinations env (optional):
# IMAGE_GEN_POLL_ROUNDS=8
# IMAGE_GEN_POLL_TIMEOUT=120
# IMAGE_GEN_POLL_PER_SEED_TRIES=4
# IMAGE_GEN_POLL_429_BACKOFF=15
# IMAGE_GEN_POLL_ROUND_SLEEP=20
# IMAGE_GEN_URL_PROMPT_MAX=1100
# IMAGE_GEN_STRICT=0   # 1 = never write blue silhouette placeholder
# Outer retries per character (agents/story_agent/agent.py ImageSynthesizer):
# IMAGE_GEN_SYNTH_MAX_ATTEMPTS=6
# IMAGE_GEN_SYNTH_BACKOFF_SEC=22

# -----------------------------------------------------------------------------
# Video Generation
# -----------------------------------------------------------------------------

# Alibaba DashScope API key (used for Wan2.1 video generation in video_gen.py)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Pexels API key (used for stock footage in video_gen.py)
# Pexels: set PEXELS_API_KEY at project root .env — restart uvicorn after changes (load_dotenv runs once at startup).
# Optional aliases: PEXELS_KEY, PEXEL_API_KEY. Do not prefix with Bearer; strip quotes if present.
PEXELS_API_KEY=your_pexels_api_key_here

# Comma-separated order; first method that produces a clip >= VIDEO_GEN_MIN_BYTES wins.
# Options: pexels, hf_ai (Hugging Face LTX-Video), dashscope (Wan2.1).
# Example — stock only: VIDEO_GEN_METHODS=pexels
VIDEO_GEN_METHODS=pexels,hf_ai

# -----------------------------------------------------------------------------
# Face Swap
# -----------------------------------------------------------------------------

# Path to InsightFace inswapper_128.onnx model (used in face_swap.py)
INSIGHTFACE_MODEL_PATH=./models/insightface/inswapper_128.onnx

# -----------------------------------------------------------------------------
# Lip Sync
# -----------------------------------------------------------------------------

# HuggingFace Space ID for SadTalker AI lip sync (used in lip_sync.py)
LIP_SYNC_SPACE_ID=vinthre/SadTalker

# True = SadTalker (HF Space) replaces visuals with talking-head output (ignores Pexels pixels).
# False = FFmpeg mux: keeps Pexels/stock video and lays dialogue audio on top.
# Note: python-dotenv does NOT override variables already set in your OS/shell — unset those first.
# Restart uvicorn / re-run Phase 2 after changing this.
USE_AI_ANIMATION=False

# -----------------------------------------------------------------------------
# Pipeline Behavior
# -----------------------------------------------------------------------------

# Auto-approve HITL checkpoint without human input (1/true/yes to enable)
# Referenced in graph.py hitl_node
HITL_AUTO_APPROVE=0

# Number of scenes to generate
NUMBER_OF_SCENES=3

# Output directories
PHASE1_OUTPUT_DIR=data/outputs/phase1
PHASE2_OUTPUT_DIR=data/outputs/phase2


